# OrHaShield SCADA Security Platform — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_dev
CLICKHOUSE_PASSWORD=changeme_dev
NEO4J_PASSWORD=changeme_dev

# ── NATS ──────────────────────────────────────────────────────────────────────
NATS_SENSOR_PASS=sensor_dev_pass
NATS_AGENT_PASS=agent_dev_pass
NATS_GATEWAY_PASS=gateway_dev_pass
NATS_CP_PASS=cp_dev_pass

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod
API_KEY=dev_api_key_change_in_prod

# ── Agent Orchestrator ────────────────────────────────────────────────────────
# Disable autonomous mode by default — enable only via explicit policy override
ORHASHIELD_AUTONOMOUS_MODE=disabled

# Digital twin simulation endpoint (Phase 2)
TWIN_API_URL=http://localhost:8001

# LangSmith tracing (disable for air-gap)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ── DPI Sensor ────────────────────────────────────────────────────────────────
CAPTURE_INTERFACE=eth0
SENSOR_ID=sensor-01

# ── Dashboard ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_dev

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
RUST_LOG=info
